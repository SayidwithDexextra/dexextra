# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.legacy-contracts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

temp-match-test.ts

# secrets / local dev artifacts
AdvancedMarketAutomation/
scripts/update-vercel-env.sh
relayers.generated.json
relayers.generated.v2.json
relayers.*.json
relayers.*.csv

# Local one-off / debugging script files (kept untracked).
# Already-tracked scripts under scripts/ continue to be tracked normally;
# this only hides ad-hoc investigation scripts so they don't pollute git status.
# scripts/git-hooks/ is preserved because it backs the no-private-keys workflow
# and is referenced from package.json.
scripts/
!scripts/git-hooks/
!scripts/git-hooks/**

# Temp working dirs (relayer/env cleanup, etc.)
.tmp-*/
